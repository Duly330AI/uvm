# Production Environment Variables
# Copy to .env and fill in actual values

# Django Secret Key (REQUIRED - generate with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())')
SECRET_KEY=example-secret-key-change-me

# Allowed Hosts (comma-separated, no spaces)
DJANGO_ALLOWED_HOSTS=example.com,www.example.com

# CSRF Trusted Origins (comma-separated with protocol)
DJANGO_CSRF_TRUSTED_ORIGINS=https://example.com,https://www.example.com

# Database
POSTGRES_DB=landlord
POSTGRES_USER=landlord
POSTGRES_PASSWORD=change-me-in-production

# Redis
REDIS_URL=redis://redis:6379/0

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_HOST_USER=example@example.com
EMAIL_HOST_PASSWORD=change-me
DEFAULT_FROM_EMAIL=noreply@example.com

# S3/MinIO
USE_S3=true
AWS_ACCESS_KEY_ID=change-me
AWS_SECRET_ACCESS_KEY=change-me
AWS_STORAGE_BUCKET_NAME=uvm-uploads-example
AWS_S3_ENDPOINT_URL=http://localhost:9000

# Security
SECURE_SSL_REDIRECT=1
SECURE_HSTS_SECONDS=31536000
SECURE_PROXY_SSL_HEADER=true

# Site
SITE_DOMAIN=example.com

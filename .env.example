# ═══════════════════════════════════════════════════════════════════════════
# ⚠️  DEVELOPMENT ENVIRONMENT VARIABLES - DO NOT USE IN PRODUCTION! ⚠️
# ═══════════════════════════════════════════════════════════════════════════
#
# This file contains INSECURE default values for LOCAL DEVELOPMENT ONLY.
#
# 🔴 NEVER use these values in production!
# 🔴 NEVER commit your actual .env file to version control!
#
# For production deployment:
# 1. Copy this file to .env
# 2. Generate secure SECRET_KEY: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# 3. Update ALL credentials with production-secure values
# 4. Use environment-specific values for databases, Redis, S3
# ═══════════════════════════════════════════════════════════════════════════

DJANGO_SETTINGS_MODULE=config.settings.dev

# SECRET_KEY: REQUIRED! Generate secure key with:
# Command: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Phase 1.3 (2025-10-22): No default fallback - MUST be set explicitly
SECRET_KEY=REPLACE_WITH_GENERATED_KEY_DO_NOT_USE_change-me

# Database: Change credentials in production!
DATABASE_URL=postgres://landlord:landlord@db:5432/landlord

REDIS_URL=redis://redis:6379/0

# Email (Development: MailHog, Production: Real SMTP)
EMAIL_HOST=mailhog
EMAIL_PORT=1025
DEFAULT_FROM_EMAIL=noreply@example.com

# S3/MinIO Storage (Development defaults - CHANGE IN PRODUCTION!)
USE_S3=false
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=minio           # ⚠️ CHANGE IN PRODUCTION!
S3_SECRET_KEY=minio123        # ⚠️ CHANGE IN PRODUCTION!
S3_BUCKET=uvm-media

DJANGO_LOG_LEVEL=INFO
